# ---- IDE / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---- Project data (downloaded via nba_api, never committed) ----
# Ignore le contenu de data/ mais garde la structure de dossiers (.gitkeep).
data/*
!data/raw/
!data/processed/
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# ---- Generated reports (figures are regenerated by evaluate.py) ----
reports/figures/*.png
reports/figures/*.jpg
reports/metrics_*.json
!reports/figures/.gitkeep

# ---- Trained model artifact (regenerated by train.py) ----
models/*.joblib
