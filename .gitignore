# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Jupyter ----
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ---- Tooling / caches ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
